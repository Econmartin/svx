# SVX environment

# === Network ===
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com

# === Operator ===
# Path to a Sui keystore JSON exported with `sui keytool export <addr>`
# The bot will load the active address from the local sui CLI by default.
# Override with this if running headless:
# SUI_PRIVATE_KEY_BECH32=suiprivkey1...

# === Strategy tunables (defaults can be overridden at runtime) ===
PAPER_TRADING=true
SPREAD_THRESHOLD=0.03
# Week-1 live defaults: $15 per trade × 10 max open = $150 max in-flight.
# Daily loss limit auto-pauses for 24h once 24h-rolling PnL hits -$150.
MAX_POSITION_DUSDC=15
MAX_POSITION_PCT=0.05
DAILY_LOSS_LIMIT_DUSDC=150
MAX_OPEN_POSITIONS=10
# Concentration cap: stop pyramiding into the same (oracle, strike, direction)
# after this many open positions. Forces diversification across signals.
MAX_POSITIONS_PER_SIGNAL=2
# Skip deep-ITM/OTM signals (protocol rejects asks > 99% or < 1%).
MIN_PREDICT_PROB=0.05
MAX_PREDICT_PROB=0.95
MAX_SVI_STALENESS_SEC=300
POLY_MAX_BIDASK_VOL_PTS=0.05
POLY_MIN_24H_VOLUME_USD=1000
# 14d. Predict's IV is repriced at the Polymarket expiry in signal/spread.ts;
# this is now a sanity cap, not the primary gate. Drop to ~24h if you want to
# limit extrapolation when SVI surfaces are noisy.
EXPIRY_TOLERANCE_SEC=1209600
CIRCUIT_BREAKER_LOSSES=5

# === Polymarket ===
POLYMARKET_API_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com

# === Polymarket execution (v2 hedged second leg) ===
# OFF by default. Critical safety gate — set true only after the bug-flush
# trade succeeds end-to-end and you've sized MAX_POLY_POSITION_USDC tiny.
POLY_EXECUTION_ENABLED=false
# 'amoy' (testnet, chain 80002, free) or 'polygon' (mainnet, chain 137, real $).
POLY_NETWORK=amoy
# Optional overrides — leave blank to use safe defaults derived from POLY_NETWORK.
# POLY_CLOB_HOST=
# POLY_RPC_URL=
# Generated locally — print + copy with: pnpm --filter svx-bot generate-poly-wallet
# POLY_PRIVATE_KEY=0x...
# Generated by setup-poly-wallet (also persisted to data/poly-operator.<network>.json):
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_API_PASSPHRASE=
# Per-trade pUSD cap on the Polymarket leg. Start tiny.
MAX_POLY_POSITION_USDC=2
# Max concurrent open Polymarket positions. Total exposure ≤ MAX_POLY * MAX_OPEN.
MAX_OPEN_POLY_POSITIONS=5
# Refuse if the best ask has fewer than this many shares available.
POLY_MIN_BOOK_DEPTH_SHARES=20
# Daily pUSD loss limit (separate from dUSDC daily limit).
DAILY_POLY_LOSS_LIMIT_USDC=10
# Max time (ms) to wait for the Polymarket leg to fill before aborting.
POLY_FILL_TIMEOUT_MS=30000
# Signature mode: 'EOA' (direct, whitelist-only), 'POLY_PROXY' (legacy), or
# 'POLY_GNOSIS_SAFE' (most setups — Polymarket deploys a Safe proxy when you
# first log into polymarket.com with the EOA). See mainnet-runbook §1.4.5.
POLY_SIGNATURE_TYPE=EOA
# Address that owns the pUSD + outcome shares. Leave empty when SIGNATURE_TYPE=EOA
# (defaults to the EOA itself). Required for POLY_PROXY / POLY_GNOSIS_SAFE.
# POLY_FUNDER_ADDRESS=0x...

# === Hyperliquid delta hedge (Part 2 — OFF by default) ===
# Set true after the one-time bridge funding + force-hl-trade verification.
HL_EXECUTION_ENABLED=false
# 'mainnet' or 'testnet'. Testnet routes to api.hyperliquid-testnet.xyz.
HL_NETWORK=mainnet
# Asset to hedge with — must match HL's perp universe. BTC = asset index 0.
HL_HEDGE_ASSET=BTC
# Generated with: pnpm --filter svx-bot generate-hl-wallet
# HL_PRIVATE_KEY=0x...
# Per-trade USD-notional cap on the HL hedge.
MAX_HL_PER_TRADE_USDC=2
# Total open HL exposure cap (sum of all open hedges, USD).
MAX_HL_OPEN_USDC=10
# Daily HL loss limit (USD) — auto-pauses bot on breach.
DAILY_HL_LOSS_LIMIT_USDC=5
# Strict mode: refuse new Poly trades when HL is unreachable. Default false
# (open naked Poly, log warning).
HL_REQUIRED_FOR_POLY=false

# === Vol-arb standalone strategy (Hyperliquid-only, no Polymarket) ===
# Trades when Predict's ATM IV diverges from HL's realized vol AND the SVI
# surface has a clear directional bias. Independent from poly-arb.
VOL_ARB_ENABLED=false
# Open trigger: |Predict IV - HL realized vol| > this (vol points)
VOL_ARB_OPEN_THRESHOLD=0.05
# Close trigger: spread falls below this
VOL_ARB_CLOSE_THRESHOLD=0.02
# Surface-bias trigger: |P(spot > spot at expiry) - 0.5| > this
VOL_ARB_DIRECTION_BIAS=0.03
# Bias-gate bypass: skip the surface-neutrality check when |IV-RV spread|
# exceeds this magnitude (vol thesis dominates direction at extreme spreads).
# Default 0.15 (15 vol points). Set to 1.0 to effectively disable.
VOL_ARB_BIAS_BYPASS_SPREAD=0.15
# Per-trade USD-notional cap on vol-arb perp positions
MAX_VOL_ARB_PER_TRADE_USDC=2
# Total open vol-arb exposure cap (USD)
MAX_VOL_ARB_OPEN_USDC=10
# Daily vol-arb loss limit (USD); auto-pauses on breach
DAILY_VOL_ARB_LOSS_LIMIT_USDC=5
# Max minutes a vol-arb position stays open before time-stop close
VOL_ARB_TIME_STOP_MINUTES=60
# Min HL mid samples in the rolling buffer before the strategy fires
VOL_ARB_MIN_SAMPLES=30

# === Margin-Lever strategy (paper-mode three-protocol composition) ===
# Predict signal (SVI bias) drives a leveraged BTC spot position constructed
# as a real PTB against deepbook_margin + iron_bank, but never signed in v1.
# Strategy ledgers simulated PnL; flipping to live execution requires the
# operator to fund USDsui collateral on iron_bank first.
MARGIN_LEVER_ENABLED=false
# Open trigger: |P(↑) at spot - 0.5| > this (probability points)
MARGIN_LEVER_OPEN_BIAS=0.10
# Close trigger: bias decays below this
MARGIN_LEVER_CLOSE_BIAS=0.04
# Time-stop in minutes
MARGIN_LEVER_MAX_HOLD_MINUTES=45
# Per-trade notional cap (dUSDC, paper)
MARGIN_LEVER_PER_TRADE_NOTIONAL_USDC=500
# Max outstanding borrow notional across all open paper positions
MARGIN_LEVER_MAX_BORROW_NOTIONAL_USDC=1500
# Daily simulated-loss limit; auto-pauses the strategy on breach
MARGIN_LEVER_DAILY_LOSS_LIMIT_USDC=100
# Ticker interval
MARGIN_LEVER_TICK_MS=15000

# === Storage ===
SVX_DATA_DIR=./data

# === Alerts (optional) ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === API server ===
SVX_API_PORT=4321
SVX_API_HOST=127.0.0.1

# === Instance label (optional) ===
# Surfaces as a coloured badge on the dashboard header so two parallel
# deployments are visually distinguishable. Common values: testnet, mainnet.
# SVX_INSTANCE_LABEL=testnet

# === Dashboard build args (one dashboard, two bots) ===
# Both URLs are baked into the Next.js client bundle at build time and read
# at runtime by every page via lib/network-context.tsx. The header's network
# toggle switches the active API client between the two. Leave the mainnet
# URL empty to disable the toggle (testnet-only dashboard).
#
# Local dev (compose hostnames):
# NEXT_PUBLIC_SVX_API=http://bot:4321
# NEXT_PUBLIC_SVX_API_MAINNET=http://bot-mainnet:4321
#
# Hosted (HTTPS — Coolify Let's Encrypt or similar):
# NEXT_PUBLIC_SVX_API=https://svx-testnet.<your-domain>
# NEXT_PUBLIC_SVX_API_MAINNET=https://svx-mainnet.<your-domain>
