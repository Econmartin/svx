# SVX environment

# === Network ===
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com

# === Operator ===
# Path to a Sui keystore JSON exported with `sui keytool export <addr>`
# The bot will load the active address from the local sui CLI by default.
# Override with this if running headless:
# SUI_PRIVATE_KEY_BECH32=suiprivkey1...

# === Strategy tunables (defaults can be overridden at runtime) ===
PAPER_TRADING=true
SPREAD_THRESHOLD=0.03
# Week-1 live defaults: $15 per trade × 10 max open = $150 max in-flight.
# Daily loss limit auto-pauses for 24h once 24h-rolling PnL hits -$150.
MAX_POSITION_DUSDC=15
MAX_POSITION_PCT=0.05
DAILY_LOSS_LIMIT_DUSDC=150
MAX_OPEN_POSITIONS=10
# Concentration cap: stop pyramiding into the same (oracle, strike, direction)
# after this many open positions. Forces diversification across signals.
MAX_POSITIONS_PER_SIGNAL=2
# Skip deep-ITM/OTM signals (protocol rejects asks > 99% or < 1%).
MIN_PREDICT_PROB=0.05
MAX_PREDICT_PROB=0.95
MAX_SVI_STALENESS_SEC=300
POLY_MAX_BIDASK_VOL_PTS=0.05
POLY_MIN_24H_VOLUME_USD=1000
EXPIRY_TOLERANCE_SEC=3600
CIRCUIT_BREAKER_LOSSES=5

# === Polymarket ===
POLYMARKET_API_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com

# === Polymarket execution (v2 hedged second leg) ===
# OFF by default. Critical safety gate — set true only after the bug-flush
# trade succeeds end-to-end and you've sized MAX_POLY_POSITION_USDC tiny.
POLY_EXECUTION_ENABLED=false
# 'amoy' (testnet, chain 80002, free) or 'polygon' (mainnet, chain 137, real $).
POLY_NETWORK=amoy
# Optional overrides — leave blank to use safe defaults derived from POLY_NETWORK.
# POLY_CLOB_HOST=
# POLY_RPC_URL=
# Generated locally — print + copy with: pnpm --filter svx-bot generate-poly-wallet
# POLY_PRIVATE_KEY=0x...
# Generated by setup-poly-wallet (also persisted to data/poly-operator.<network>.json):
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_API_PASSPHRASE=
# Per-trade pUSD cap on the Polymarket leg. Start tiny.
MAX_POLY_POSITION_USDC=2
# Max concurrent open Polymarket positions. Total exposure ≤ MAX_POLY * MAX_OPEN.
MAX_OPEN_POLY_POSITIONS=5
# Refuse if the best ask has fewer than this many shares available.
POLY_MIN_BOOK_DEPTH_SHARES=20
# Daily pUSD loss limit (separate from dUSDC daily limit).
DAILY_POLY_LOSS_LIMIT_USDC=10
# Max time (ms) to wait for the Polymarket leg to fill before aborting.
POLY_FILL_TIMEOUT_MS=30000

# === Hyperliquid delta hedge (Part 2 — OFF by default) ===
# Set true after the one-time bridge funding + force-hl-trade verification.
HL_EXECUTION_ENABLED=false
# 'mainnet' or 'testnet'. Testnet routes to api.hyperliquid-testnet.xyz.
HL_NETWORK=mainnet
# Asset to hedge with — must match HL's perp universe. BTC = asset index 0.
HL_HEDGE_ASSET=BTC
# Generated with: pnpm --filter svx-bot generate-hl-wallet
# HL_PRIVATE_KEY=0x...
# Per-trade USD-notional cap on the HL hedge.
MAX_HL_PER_TRADE_USDC=2
# Total open HL exposure cap (sum of all open hedges, USD).
MAX_HL_OPEN_USDC=10
# Daily HL loss limit (USD) — auto-pauses bot on breach.
DAILY_HL_LOSS_LIMIT_USDC=5
# Strict mode: refuse new Poly trades when HL is unreachable. Default false
# (open naked Poly, log warning).
HL_REQUIRED_FOR_POLY=false

# === Storage ===
SVX_DATA_DIR=./data

# === Alerts (optional) ===
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === API server ===
SVX_API_PORT=4321
SVX_API_HOST=127.0.0.1

# === Instance label (optional) ===
# Surfaces as a coloured badge on the dashboard header so two parallel
# deployments are visually distinguishable. Common values: testnet, mainnet.
# SVX_INSTANCE_LABEL=testnet

# === Dashboard build args (one dashboard, two bots) ===
# Both URLs are baked into the Next.js client bundle at build time. The
# dashboard's `/` pages talk to NEXT_PUBLIC_SVX_API (testnet Predict bot);
# `/mainnet` pages talk to NEXT_PUBLIC_SVX_API_MAINNET (mainnet Polymarket
# bot). Leave the mainnet URL empty to disable the /mainnet page.
# NEXT_PUBLIC_SVX_API=http://bot:4321
# NEXT_PUBLIC_SVX_API_MAINNET=http://bot-mainnet:4321
