# Use a flat node_modules layout (npm-style) instead of pnpm's nested
# symlinks. Required for Next.js standalone Docker builds — the symlinked
# layout doesn't survive the COPY into the runner image.
node-linker=hoisted
shamefully-hoist=true

# Strict peer dependency checks off — some dashboard deps (recharts) lag
# react versions slightly. Acceptable for runtime.
strict-peer-dependencies=false
auto-install-peers=true
